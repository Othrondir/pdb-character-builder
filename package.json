{
  "name": "nwn1-character-builder",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build:planner": "corepack pnpm --dir apps/planner build",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "dev:planner": "corepack pnpm --dir apps/planner dev",
    "extract": "pnpm --filter @pdb/data-extractor extract",
    "test": "vitest run",
    "test:phase-01": "vitest run tests/phase-01 --reporter=dot",
    "test:phase-02": "vitest run tests/phase-02 --reporter=dot",
    "test:phase-08": "vitest run tests/phase-08 --reporter=dot",
    "test:e2e": "playwright test",
    "test:e2e:phase-12.8": "playwright test tests/phase-12.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@fontsource/cormorant-garamond": "latest",
    "@fontsource/spectral": "latest",
    "@playwright/test": "^1.58.0",
    "@tanstack/react-router": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "fake-indexeddb": "^6.2.5",
    "fflate": "^0.8.2",
    "fzstd": "^0.1.1",
    "jsdom": "latest",
    "lucide-react": "latest",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "typescript": "5.9.2",
    "vite": "^8.0.0",
    "vitest": "4.0.16",
    "zod": "4.3.5",
    "zustand": "latest"
  }
}
